[Unit]
Description=Hermes Agent
After=network-online.target

[Service]
Type=simple
User=${user}
Group=${user}
WorkingDirectory=/home/${user}
Environment=PATH=/home/${user}/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/${user}
# Credentials provisioned by bw from TeamVault; missing file is OK
# (gateway will fail to authenticate but won't refuse to start).
EnvironmentFile=-${credentials_file}
ExecStart=/home/${user}/.local/bin/hermes gateway run --replace
Restart=on-failure
RestartSec=10
# Hermes drain_timeout=180s; give it >=210s before systemd SIGKILLs mid-drain.
TimeoutStopSec=210

[Install]
WantedBy=multi-user.target
